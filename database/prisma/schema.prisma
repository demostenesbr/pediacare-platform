generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum ContentChannel {
  linkedin
  medium
}

model Content {
  id        String         @id @default(cuid())
  title     String
  summary   String
  body      String
  channel   ContentChannel
  tags      Json
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}
